# Copy this file to .env on the Linux Docker host, or run:
#   ./scripts/init-env.sh

COMPOSE_PROJECT_NAME=game-panel

# Absolute persistent data path on the Docker host.
# MCSManager's daemon controls host Docker through /var/run/docker.sock, so this
# should be an absolute host path, not a container-only path.
MCSM_ROOT=/srv/game-panel

# Absolute host path where all MCSManager game instances are stored.
# scripts/init-env.sh sets this to <project>/instances on the NUC.
MCSM_INSTANCE_ROOT=/srv/game-panel/instances

# MCSManager official images.
MCSM_IMAGE_TAG=latest
# LAN mode: expose management ports on the NUC's LAN IP.
# Use 127.0.0.1 instead if you only want local/Sakura access.
MCSM_WEB_BIND=0.0.0.0
MCSM_WEB_PORT=23333
MCSM_DAEMON_BIND=0.0.0.0
MCSM_DAEMON_PORT=24444
GAME_NETWORK_NAME=game-panel

LOG_MAX_SIZE=10m
LOG_MAX_FILE=3
